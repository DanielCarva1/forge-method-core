#!/bin/sh
# Forge release wrapper (POSIX shell) — delegates to forge-core beside it.
# Every declared package target provides /bin/sh; fixing the interpreter path
# keeps interpreter selection outside an attacker-controlled PATH.
#
# Supported release packages are GNU/Linux x86_64/aarch64 and macOS
# x86_64/arm64.  Invocation-symlink resolution is deliberately limited to
# those targets and to system-controlled uname, getconf, and readlink paths;
# an attacker-selected PATH is never used for those utilities.  The Linux
# GNU ABI check uses glibc's getconf query because uname cannot identify libc.
#
# The Forge Method skill (`start-forge`) looks for a `forge` command on PATH
# first, falling back to `forge-core`. Install both files from the archive:
#
#     tar xzf forge-core-<arch>-<os>.tar.gz
#     install -m 0755 forge forge-core ~/.local/bin/
#
# The resolved wrapper directory is made physical with `cd -P`, and the
# packaged binary must be a non-symlink regular file in that directory. Thus
# a PATH entry, relocation, or wrapper symlink cannot select another core.
set -eu

fail() {
    printf '%s\n' "forge wrapper: $*" >&2
    exit 127
}

# A shell may pass only the command name in $0 when PATH lookup was used.
# Split PATH with parameter expansion rather than IFS field splitting: POSIX
# lookup treats every empty component (including a wholly empty PATH and the
# leading/interior/trailing cases) as the current directory, while shell field
# splitting is permitted to discard trailing empty fields.
self=$0
case $self in
    */*) ;;
    *)
        [ "${PATH+x}" = x ] || fail "cannot locate wrapper $self through an unset PATH"
        path_rest=$PATH
        found=
        while :; do
            case $path_rest in
                *:*) entry=${path_rest%%:*}; path_rest=${path_rest#*:}; more=1 ;;
                *) entry=$path_rest; more= ;;
            esac
            [ -n "$entry" ] || entry=.
            candidate=$entry/$self
            # Match executable PATH lookup: skip non-executable files and
            # dangling links rather than shadowing a later entry.
            if [ -f "$candidate" ] && [ -x "$candidate" ]; then
                self=$candidate
                found=1
                break
            fi
            [ -n "$more" ] || break
        done
        [ -n "$found" ] || fail "cannot locate wrapper $self through PATH"
        ;;
esac

# Choose a resolver only after verifying the supported release boundary with
# system-controlled tools. readlink is not POSIX; accept it only at fixed
# system locations expected on declared targets, and fail closed if absent.
select_readlink() {
    uname_bin=
    if [ -f /usr/bin/uname ] && [ -x /usr/bin/uname ]; then
        uname_bin=/usr/bin/uname
    elif [ -f /bin/uname ] && [ -x /bin/uname ]; then
        uname_bin=/bin/uname
    else
        fail "cannot resolve invocation symlink: no trusted platform detector"
    fi
    if ! platform_os=$("$uname_bin" -s 2>/dev/null) ||
       ! platform_arch=$("$uname_bin" -m 2>/dev/null); then
        fail "cannot resolve invocation symlink: platform detection failed"
    fi

    case $platform_os:$platform_arch in
        Linux:x86_64|Linux:aarch64)
            getconf_bin=
            if [ -f /usr/bin/getconf ] && [ -x /usr/bin/getconf ]; then
                getconf_bin=/usr/bin/getconf
            elif [ -f /bin/getconf ] && [ -x /bin/getconf ]; then
                getconf_bin=/bin/getconf
            else
                fail "unsupported symlink resolver platform: GNU libc not detected"
            fi
            if ! libc_version=$("$getconf_bin" GNU_LIBC_VERSION 2>/dev/null); then
                fail "unsupported symlink resolver platform: GNU libc not detected"
            fi
            case $libc_version in
                "glibc "?*) ;;
                *) fail "unsupported symlink resolver platform: GNU libc not detected" ;;
            esac
            if [ -f /usr/bin/readlink ] && [ -x /usr/bin/readlink ]; then
                readlink_bin=/usr/bin/readlink
            elif [ -f /bin/readlink ] && [ -x /bin/readlink ]; then
                readlink_bin=/bin/readlink
            else
                fail "cannot resolve invocation symlink: no trusted resolver"
            fi
            ;;
        Darwin:x86_64|Darwin:arm64)
            if [ -f /usr/bin/readlink ] && [ -x /usr/bin/readlink ]; then
                readlink_bin=/usr/bin/readlink
            else
                fail "cannot resolve invocation symlink: no trusted resolver"
            fi
            ;;
        *)
            fail "unsupported symlink resolver platform: $platform_os/$platform_arch"
            ;;
    esac
}

# Resolve every invocation symlink, including relative targets. The bound fails
# closed on loops. A sentinel preserves target names ending in newlines; the
# two suffix removals discard only the sentinel and readlink's output delimiter.
readlink_bin=
symlink_count=0
while [ -L "$self" ]; do
    symlink_count=$((symlink_count + 1))
    [ "$symlink_count" -le 40 ] || fail "symlink loop while resolving $0"
    if [ -z "$readlink_bin" ]; then
        select_readlink
    fi
    if ! target=$("$readlink_bin" "$self" && printf '\001'); then
        fail "cannot read invocation symlink $self"
    fi
    target=${target%?}
    target=${target%?}
    case $target in
        /*) self=$target ;;
        *)
            case $self in
                */*) base=${self%/*}; [ -n "$base" ] || base=/ ;;
                *) base=. ;;
            esac
            self=$base/$target
            ;;
    esac
done

[ -f "$self" ] && [ ! -L "$self" ] || fail "wrapper target is not a regular file: $self"
case $self in
    */*) bin_dir=${self%/*}; [ -n "$bin_dir" ] || bin_dir=/ ;;
    *) bin_dir=. ;;
esac
if ! bin_dir=$(CDPATH= cd -P "$bin_dir" 2>/dev/null && pwd -P && printf '\001'); then
    fail "cannot resolve package directory for $self"
fi
bin_dir=${bin_dir%?}
bin_dir=${bin_dir%?}

binary=$bin_dir/forge-core
if [ ! -f "$binary" ] || [ -L "$binary" ] || [ ! -x "$binary" ]; then
    fail "missing or unsafe packaged binary: $binary"
fi

exec "$binary" "$@"
