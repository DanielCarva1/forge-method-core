#!/usr/bin/env sh
# Forge wrapper (POSIX) — delegates to forge-core in the same directory.
#
# The Forge Method skill (`start-forge`) looks for a `forge` command on PATH
# first, falling back to `forge-core`. This thin wrapper lets releases ship a
# single archive containing both names, so users do not have to alias anything
# themselves. Install this file alongside `forge-core` with executable bits:
#
#     tar xzf forge-core-<arch>-<os>.tar.gz
#     install -m 0755 forge forge-core ~/.local/bin/
#
# The wrapper follows invocation symlinks without relying on non-POSIX
# `readlink` extensions.  The resolved wrapper directory is made physical
# with `cd -P`, and the packaged binary must be a non-symlink regular file in
# that directory.  Thus a PATH entry, relocation, or wrapper symlink cannot
# redirect execution to a different `forge-core`.
set -eu

fail() {
    printf '%s\n' "forge wrapper: $*" >&2
    exit 127
}

# A shell may pass only the command name in $0 when PATH lookup was used.
# Locate that name with IFS set to colon so spaces and embedded newlines stay
# in one pathname; disabling globbing prevents PATH characters from expanding.
self=$0
case $self in
    */*) ;;
    *)
        path=${PATH-}
        [ -n "$path" ] || fail "cannot locate wrapper $self through an unset or empty PATH"
        old_ifs=$IFS
        IFS=:
        set -f
        found=
        for entry in $path; do
            [ -n "$entry" ] || entry=.
            candidate=$entry/$self
            # Match the shell's executable PATH lookup: skip non-executable
            # files and dangling links rather than shadowing a later entry.
            if [ -f "$candidate" ] && [ -x "$candidate" ]; then
                self=$candidate
                found=1
                break
            fi
        done
        IFS=$old_ifs
        [ -n "$found" ] || fail "cannot locate wrapper $self through PATH"
        ;;
esac

# Resolve every invocation symlink, including relative targets.  The bound is
# deliberate: a loop fails closed instead of hanging.  A sentinel preserves
# trailing newlines; the two suffix removals discard only output delimiters.
# readlink is not a POSIX utility, so use only trusted system locations and do
# not let an attacker-selected PATH replace the resolver.
readlink_bin=
symlink_count=0
while [ -L "$self" ]; do
    symlink_count=$((symlink_count + 1))
    [ "$symlink_count" -le 40 ] || fail "symlink loop while resolving $0"
    if [ -z "$readlink_bin" ]; then
        if [ -f /usr/bin/readlink ] && [ -x /usr/bin/readlink ]; then
            readlink_bin=/usr/bin/readlink
        elif [ -f /bin/readlink ] && [ -x /bin/readlink ]; then
            readlink_bin=/bin/readlink
        else
            fail "cannot resolve invocation symlink: no supported resolver"
        fi
    fi
    if ! target=$("$readlink_bin" "$self" && printf '\001'); then
        fail "cannot read invocation symlink $self"
    fi
    target=${target%?}
    target=${target%?}
    case $target in
        /*) self=$target ;;
        *)
            case $self in
                */*) base=${self%/*}; [ -n "$base" ] || base=/ ;;
                *) base=. ;;
            esac
            self=$base/$target
            ;;
    esac
done

[ -f "$self" ] && [ ! -L "$self" ] || fail "wrapper target is not a regular file: $self"
case $self in
    */*) bin_dir=${self%/*}; [ -n "$bin_dir" ] || bin_dir=/ ;;
    *) bin_dir=. ;;
esac
if ! bin_dir=$(CDPATH= cd -P "$bin_dir" 2>/dev/null && pwd -P && printf '\001'); then
    fail "cannot resolve package directory for $self"
fi
bin_dir=${bin_dir%?}
bin_dir=${bin_dir%?}

binary=$bin_dir/forge-core
if [ ! -f "$binary" ] || [ -L "$binary" ] || [ ! -x "$binary" ]; then
    fail "missing or unsafe packaged binary: $binary"
fi

exec "$binary" "$@"
