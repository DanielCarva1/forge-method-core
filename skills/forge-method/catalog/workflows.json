    {"id": "edge-case-review", "phase": "anytime", "required": false, "followed_by": ["risk-register", "build-story"], "outputs": ["edge-case findings", "follow-up stories"], "facilitation_pack": "document-utility", "template": "document-utility-artifact", "modes": ["analyze", "validate"]},
    {"id": "spec-distillation", "phase": "1-discovery | 2-specification", "required": false, "followed_by": ["write-spec", "product-requirements", "plan-sprint"], "outputs": ["spec kernel", "assumptions", "open questions"], "facilitation_pack": "document-utility", "template": "document-utility-artifact", "modes": ["create", "resume", "validate", "headless"]},
    {"id": "game-project", "phase": "1-discovery", "required": false, "followed_by": ["game-brief"], "outputs": ["game project route"]},
    {"id": "game-brief", "phase": "1-discovery", "required": true, "followed_by": ["gdd", "game-ux-design", "game-prd", "quick-prototype"], "outputs": ["game brief", "decision log"], "facilitation_pack": "game-brief"},
    {"id": "gdd", "phase": "2-specification", "required": true, "followed_by": ["narrative-design", "mechanics-design", "game-ux-design", "game-prd", "engine-architecture"], "outputs": ["game design document"], "facilitation_pack": "game-lifecycle"},
    {"id": "narrative-design", "phase": "2-specification", "required": false, "outputs": ["narrative design"], "facilitation_pack": "game-lifecycle"},
    {"id": "mechanics-design", "phase": "2-specification", "required": true, "outputs": ["mechanics matrix"], "facilitation_pack": "game-lifecycle"},
    {"id": "game-ux-design", "phase": "2-specification | 3-plan", "required": false, "followed_by": ["game-prd", "game-story-creation"], "outputs": ["game UX plan", "interaction map"], "facilitation_pack": "game-lifecycle", "template": "game-lifecycle-artifact", "modes": ["create", "update", "validate"]},
    {"id": "game-prd", "phase": "2-specification | 3-plan", "required": false, "followed_by": ["create-epics", "game-story-creation"], "outputs": ["game PRD", "acceptance/evidence map"], "facilitation_pack": "game-lifecycle", "template": "game-lifecycle-artifact", "modes": ["create", "update", "validate"]},
    {"id": "engine-architecture", "phase": "3-plan", "required": true, "outputs": ["engine architecture"], "facilitation_pack": "game-lifecycle"},
    {"id": "quick-prototype", "phase": "4-build-verify", "required": false, "outputs": ["prototype proof"], "facilitation_pack": "game-lifecycle"},
    {"id": "game-story-creation", "phase": "3-plan", "required": false, "followed_by": ["build-story", "game-sprint-status"], "outputs": ["game story files", "story order"], "facilitation_pack": "game-lifecycle", "template": "game-lifecycle-artifact", "modes": ["create", "resume", "validate"]},
