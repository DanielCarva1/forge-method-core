{
  "schema_version": "forge-workflow-catalog.v1",
  "workflows": [
    {"id": "start-runtime", "reference": "start", "phase": "0-route", "required": true, "followed_by": ["guide-route", "discover-intent"], "outputs": ["route decision", "project state"]},
    {"id": "discover-intent", "phase": "1-discovery", "required": true, "followed_by": ["reality-evidence-gate", "write-spec"], "outputs": ["intent", "constraints", "success criteria"], "facilitation_pack": "discover-intent"},
    {"id": "guide-route", "phase": "anytime", "required": false, "followed_by": ["guidance-engine"], "outputs": ["route recommendation"]},
    {"id": "guidance-engine", "phase": "anytime", "required": true, "outputs": ["intent classification", "recommended workflow", "commands"]},
    {"id": "reality-evidence-gate", "phase": "1-discovery", "required": true, "followed_by": ["market-scan", "domain-scan", "technical-feasibility-scan"], "outputs": ["feasibility stance", "evidence needs"], "facilitation_pack": "evidence-research"},
    {"id": "market-scan", "phase": "1-discovery", "required": false, "outputs": ["market evidence"], "facilitation_pack": "evidence-research"},
    {"id": "domain-scan", "phase": "1-discovery", "required": false, "outputs": ["domain constraints"], "facilitation_pack": "evidence-research"},
    {"id": "technical-feasibility-scan", "phase": "1-discovery", "required": false, "outputs": ["technical feasibility evidence"], "facilitation_pack": "evidence-research"},
    {"id": "brainstorming", "phase": "1-discovery", "required": false, "followed_by": ["concept-selection"], "outputs": ["option set"], "facilitation_pack": "brainstorming"},
    {"id": "problem-solving", "phase": "1-discovery", "required": false, "followed_by": ["correct-course", "runtime-builder"], "outputs": ["problem frame", "next reversible action"], "facilitation_pack": "problem-solving"},
    {"id": "design-thinking", "phase": "1-discovery", "required": false, "outputs": ["user problem frame"], "facilitation_pack": "design-thinking"},
    {"id": "innovation-strategy", "phase": "1-discovery", "required": false, "outputs": ["innovation options"], "facilitation_pack": "creative-direction"},
    {"id": "storytelling", "phase": "2-specification", "required": false, "outputs": ["narrative arc"], "facilitation_pack": "creative-direction"},
    {"id": "creative-session", "phase": "1-discovery", "required": false, "followed_by": ["concept-selection"], "outputs": ["creative direction"], "facilitation_pack": "brainstorming"},
    {"id": "concept-selection", "phase": "1-discovery", "required": false, "followed_by": ["write-spec"], "outputs": ["selected concept", "rejected alternatives"], "facilitation_pack": "creative-direction"},
    {"id": "write-spec", "phase": "2-specification", "required": true, "followed_by": ["plan-sprint", "quick-dev"], "outputs": ["specification artifact"], "facilitation_pack": "product-planning"},
    {"id": "quick-dev", "phase": "2-specification | 4-build-verify", "required": false, "followed_by": ["build-story", "ready-release", "product-requirements", "ux-plan"], "outputs": ["spec-lite", "implementation evidence", "next workflow"], "facilitation_pack": "quick-dev", "template": "quick-dev-artifact", "modes": ["clarify", "spec-lite", "implement", "review", "headless"]},
    {"id": "product-requirements", "phase": "2-specification", "required": true, "followed_by": ["architecture", "ux-plan", "quick-dev"], "outputs": ["requirements", "decision log", "validation findings"], "facilitation_pack": "product-planning", "template": "product-requirements-artifact", "modes": ["create", "update", "validate", "addendum", "headless"]},
    {"id": "architecture", "phase": "3-plan", "required": true, "followed_by": ["create-epics"], "outputs": ["architecture notes"], "facilitation_pack": "architecture-planning"},
    {"id": "ux-plan", "phase": "3-plan", "required": false, "followed_by": ["create-epics", "quick-dev"], "outputs": ["ux plan", "taste calibration", "rejection log"], "facilitation_pack": "ux-design", "template": "ux-design-artifact", "modes": ["create", "update", "validate", "headless"]},
    {"id": "create-epics", "phase": "3-plan", "required": true, "followed_by": ["readiness-check"], "outputs": ["epics", "stories"], "facilitation_pack": "story-lifecycle"},
    {"id": "plan-sprint", "phase": "3-plan", "required": true, "followed_by": ["readiness-check"], "outputs": ["story plan", "validation plan"], "facilitation_pack": "story-lifecycle"},
    {"id": "readiness-check", "phase": "3-plan", "required": true, "followed_by": ["build-story"], "outputs": ["readiness report"], "facilitation_pack": "story-lifecycle"},
    {"id": "grill-gate", "phase": "1-discovery | 2-specification | 3-plan", "required": true, "followed_by": ["build-story"], "outputs": ["decision challenge result"], "facilitation_pack": "decision-gate"},
    {"id": "build-story", "phase": "4-build-verify", "required": true, "followed_by": ["ready-release"], "outputs": ["implementation", "evidence"]},
    {"id": "ready-release", "phase": "5-ready-operate", "required": true, "followed_by": ["evolve-project"], "outputs": ["ready evidence", "release status"], "facilitation_pack": "story-lifecycle"},
    {"id": "release-readiness", "phase": "5-ready-operate", "required": true, "outputs": ["release checklist"], "facilitation_pack": "enterprise-readiness"},
    {"id": "evolve-project", "phase": "6-evolve", "required": true, "followed_by": ["guidance-engine", "runtime-builder", "correct-course"], "outputs": ["evolution route"], "facilitation_pack": "problem-solving"},
    {"id": "correct-course", "phase": "anytime", "required": false, "followed_by": ["runtime-builder", "build-story"], "outputs": ["correction artifact"], "facilitation_pack": "correct-course"},
    {"id": "context-recovery", "phase": "anytime", "required": false, "outputs": ["recovery brief"]},
    {"id": "council-decision", "phase": "anytime", "required": false, "outputs": ["council decision"]},
    {"id": "runtime-builder", "phase": "1-discovery | 6-evolve", "required": true, "followed_by": ["builder-scaffold", "agent-analyze", "workflow-analyze", "skill-convert", "eval-design"], "outputs": ["runtime change shape"], "facilitation_pack": "runtime-builder"},
    {"id": "builder-scaffold", "phase": "4-build-verify", "required": false, "followed_by": ["workflow-validate", "eval-design"], "outputs": ["workflow/module/agent scaffold"]},
    {"id": "agent-analyze", "phase": "1-discovery | 6-evolve", "required": false, "followed_by": ["builder-scaffold", "eval-design"], "outputs": ["agent analysis", "findings"], "facilitation_pack": "builder-utility", "template": "builder-utility-artifact", "modes": ["analyze", "validate"]},
    {"id": "workflow-analyze", "phase": "1-discovery | 6-evolve", "required": false, "followed_by": ["workflow-validate", "builder-scaffold", "eval-design"], "outputs": ["workflow analysis", "gap list"], "facilitation_pack": "builder-utility", "template": "builder-utility-artifact", "modes": ["analyze", "validate"]},
    {"id": "skill-convert", "phase": "1-discovery | 6-evolve", "required": false, "followed_by": ["builder-scaffold", "workflow-validate", "eval-design"], "outputs": ["converted workflow/pack", "validation evidence"], "facilitation_pack": "builder-utility", "template": "builder-utility-artifact", "modes": ["create", "validate", "headless"]},
    {"id": "config-customization", "phase": "anytime", "required": false, "outputs": ["project config"]},
