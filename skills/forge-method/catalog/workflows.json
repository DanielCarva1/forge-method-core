    {"id": "doc-shard", "phase": "anytime", "required": false, "followed_by": ["doc-index", "editorial-review"], "outputs": ["sharded docs", "index updates"], "facilitation_pack": "document-utility", "template": "document-utility-artifact", "modes": ["create", "update", "validate"]},
