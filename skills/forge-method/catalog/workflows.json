    {"id": "playtest-plan", "phase": "4-build-verify", "required": false, "outputs": ["playtest plan"], "facilitation_pack": "game-lifecycle"},
    {"id": "performance-plan", "phase": "3-plan | 4-build-verify", "required": false, "outputs": ["performance plan"], "facilitation_pack": "game-lifecycle"},
    {"id": "game-qa-review", "phase": "4-build-verify", "required": false, "outputs": ["game QA review"], "facilitation_pack": "game-lifecycle"},
    {"id": "test-strategy", "phase": "3-plan", "required": true, "followed_by": ["test-engagement-model", "risk-register", "readiness-check"], "outputs": ["test strategy"], "facilitation_pack": "test-strategy"},
    {"id": "teach-testing", "phase": "anytime", "required": false, "followed_by": ["test-engagement-model", "test-strategy", "test-framework"], "outputs": ["testing explanation", "applied examples", "next test workflow"], "facilitation_pack": "test-architecture", "template": "test-architecture-artifact", "modes": ["teach", "explain", "resume"]},
    {"id": "test-engagement-model", "phase": "2-specification | 3-plan", "required": false, "followed_by": ["test-framework", "test-review", "nfr-evidence-audit", "traceability-gate"], "outputs": ["test engagement decision", "next quality workflow"], "facilitation_pack": "test-architecture", "template": "test-architecture-artifact", "modes": ["create", "resume"]},
    {"id": "test-framework", "phase": "3-plan | 4-build-verify", "required": false, "followed_by": ["ci-quality-pipeline", "atdd-plan", "test-automation"], "outputs": ["test framework plan", "command contract"], "facilitation_pack": "test-architecture", "template": "test-architecture-artifact", "modes": ["create", "validate"]},
