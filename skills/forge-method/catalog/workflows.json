    {"id": "test-review", "phase": "4-build-verify | 5-ready-operate", "required": false, "followed_by": ["nfr-evidence-audit", "traceability-gate"], "outputs": ["test review findings", "gate recommendation"], "facilitation_pack": "test-architecture", "template": "test-architecture-artifact", "modes": ["analyze", "validate"]},
    {"id": "nfr-evidence-audit", "phase": "5-ready-operate", "required": false, "followed_by": ["traceability-gate", "release-readiness"], "outputs": ["NFR evidence audit", "gaps and waivers"], "facilitation_pack": "test-architecture", "template": "test-architecture-artifact", "modes": ["audit", "validate"]},
    {"id": "traceability-gate", "phase": "4-build-verify | 5-ready-operate", "required": false, "followed_by": ["release-readiness", "ready-release"], "outputs": ["traceability matrix", "gate decision"], "facilitation_pack": "test-architecture", "template": "test-architecture-artifact", "modes": ["create", "validate", "gate"]},
    {"id": "risk-register", "phase": "3-plan | 5-ready-operate", "required": false, "outputs": ["risk register"], "facilitation_pack": "enterprise-readiness"},
    {"id": "security-plan", "phase": "3-plan", "required": true, "outputs": ["security plan"], "facilitation_pack": "enterprise-readiness"},
    {"id": "privacy-data-plan", "phase": "3-plan", "required": true, "outputs": ["privacy data plan"], "facilitation_pack": "enterprise-readiness"},
    {"id": "devops-deployment-plan", "phase": "3-plan | 5-ready-operate", "required": false, "outputs": ["deployment plan"], "facilitation_pack": "enterprise-readiness"},
    {"id": "compliance-checklist", "phase": "3-plan | 5-ready-operate", "required": false, "outputs": ["compliance checklist"], "facilitation_pack": "enterprise-readiness"},
    {"id": "observability-plan", "phase": "5-ready-operate", "required": false, "outputs": ["observability plan"], "facilitation_pack": "enterprise-readiness"}
  ]
}
