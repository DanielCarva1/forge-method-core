{
  "agents": [
    {
      "handoff": "Record the decision, remaining uncertainty, and exact next state action.",
      "id": "facilitator",
      "inputs": "state snapshot | open human inputs | current workflow | recent checkpoint",
      "outputs": "answered input | clarified constraint | next action | checkpoint update",
      "purpose": "Clarify intent, constraints, trade-offs, and human decisions without expanding implementation scope.",
      "title": "Facilitator",
      "when": "0-route | 1-discovery | blocked story | required human input"
    },
    {
      "handoff": "List touched files, checks, failures, and the next repair or review step.",
      "id": "implementer",
      "inputs": "active story | acceptance criteria | linked artifacts | context pack",
      "outputs": "minimal diff | checks run | evidence summary | updated story state",
      "purpose": "Apply scoped code or artifact changes for the active story and keep progress file-backed.",
      "title": "Implementer",
      "when": "4-build-verify with ready or in-progress story"
    },
    {
      "handoff": "Preserve user-facing state, support risks, and whether evolution should start.",
      "id": "operator",
      "inputs": "ready evidence | usage notes | support status | feedback",
      "outputs": "operating note | support update | future backlog item | evolution trigger",
      "purpose": "Maintain a ready project through usage notes, support status, feedback, and future backlog.",
      "title": "Operator",
      "when": "5-ready-operate"
    },
    {
      "handoff": "Preserve story order, unresolved risks, and the next executable story.",
      "id": "planner",
      "inputs": "spec artifact | risk notes | module manifest | current sprint",
      "outputs": "story plan | risk plan | validation plan | updated sprint",
      "purpose": "Turn specs, risks, and constraints into executable stories, sequencing, and validation strategy.",
      "title": "Planner",
      "when": "3-plan | blocked story | evolve planning"
    },
    {
      "handoff": "Record findings, repaired items, remaining risks, and gate status.",
      "id": "quality-reviewer",
      "inputs": "diff | story criteria | evidence ledger | gate output | artifact index",
      "outputs": "blocking findings | non-blocking findings | required checks | approval evidence",
      "purpose": "Review implementation, artifacts, workflows, and evidence before work is marked done or ready.",
      "title": "Quality Reviewer",
      "when": "story review | quality gate | audit failure | ready gate"
    },
    {
      "handoff": "Preserve sources, date, decision impact, and unresolved verification gaps.",
      "id": "researcher",
      "inputs": "question | decision to support | source constraints | freshness needs",
      "outputs": "source-backed findings | recommendation | confidence | cited evidence artifact",
      "purpose": "Collect current external or domain evidence only when it changes a decision or requirement.",
      "title": "Researcher",
      "when": "discovery uncertainty | specification risk | market or technical evidence needed"
    },
    {
      "handoff": "Preserve requirement decisions, rejected scope, and planning assumptions.",
      "id": "spec-architect",
      "inputs": "intent brief | constraints | module purpose | human decisions",
      "outputs": "requirements | acceptance criteria | boundaries | specification artifact",
      "purpose": "Convert clarified intent into requirements, acceptance criteria, boundaries, and non-goals.",
      "title": "Spec Architect",
      "when": "2-specification"
    }
  ],
